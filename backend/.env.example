PORT=3001
SUPABASE_URL=
SUPABASE_ANON_KEY=
GEMINI_API_KEY=
# Regra do produto: Gemini 3 Flash Preview para OCR. Override só se necessário.
# GEMINI_MODEL=gemini-3-flash-preview
# Se o Gemini falhar (quota, 503, etc.), o OCR usa OpenAI (imagem ou PDF em base64) — precisa de chave.
OPENAI_API_KEY=
# Padrão: gpt-4o-mini (fallback de OCR e POST /api/support/chat)
OPENAI_MODEL=gpt-4o-mini
HOSPITAL_ALERT_WEBHOOK_URL=
# Obrigatório se HOSPITAL_ALERT_WEBHOOK_URL estiver definido: HMAC-SHA256 (hex) do JSON no header X-Webhook-Signature
HOSPITAL_ALERT_WEBHOOK_SECRET=

# --- Cloudflare R2 (armazenamento S3-compatible dos ficheiros de exames) ---
# O bucket do Supabase (medical_scans) na migração inicial não é usado por este fluxo:
# o mobile envia ao backend e o backend grava no R2 quando estas variáveis existem.
# Dashboard: Cloudflare → R2 → criar bucket → Manage R2 API Tokens (S3).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Nome do bucket (use R2_BUCKET ou R2_BUCKET_NAME — ambos são aceites)
R2_BUCKET=
# R2_BUCKET_NAME=

# Opcional: por defeito o servidor escuta em 0.0.0.0 (todas as interfaces) para o telemóvel na Wi‑Fi alcançar o PC.
# LISTEN_HOST=127.0.0.1

# --- WhatsApp Cloud API (Sprint 4) — POST /api/whatsapp/send, webhook /api/whatsapp/webhook ---
# Não commite tokens. O dashboard usa VITE_BACKEND_URL e envia Bearer do Supabase.
SUPABASE_SERVICE_ROLE_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# Opcional: verificação de assinatura X-Hub-Signature-256
WHATSAPP_APP_SECRET=
# Padrão v21.0
WHATSAPP_API_VERSION=v21.0

# CORS: origens permitidas separadas por vírgula. Em NODE_ENV=production é obrigatório (senão o servidor termina ao iniciar).
# Dev: pode ficar vazio (modo permissivo).
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
