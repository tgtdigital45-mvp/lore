{
  "name": "aura-onco",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "doctor": "expo-doctor",
    "e2e:maestro": "echo \"Instale Maestro (https://maestro.mobile.dev/) e execute: maestro test maestro/smoke.yaml (ajuste appId no YAML ao bundle da build).\"",
    "start": "node ./scripts/adb-reverse.mjs --soft && expo start",
    "start:plain": "expo start",
    "start:clear": "node ./scripts/adb-reverse.mjs --soft && expo start -c",
    "start:tunnel": "expo start --tunnel",
    "adb:reverse": "node ./scripts/adb-reverse.mjs",
    "adb:reverse:soft": "node ./scripts/adb-reverse.mjs --soft",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas:login": "npx eas-cli@^18.7.0 login",
    "eas:configure": "npx eas-cli@^18.7.0 build:configure -p android",
    "eas:build:android": "npx eas-cli@^18.7.0 build --platform android --profile production",
    "eas:submit:android": "npx eas-cli@^18.7.0 submit --platform android --latest"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@kingstinct/react-native-healthkit": "^14.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.97.0",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-nitro-modules": "^0.35.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "dotenv": "^17.4.1",
    "expo-doctor": "^1.18.18",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
