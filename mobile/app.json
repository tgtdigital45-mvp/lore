{
  "expo": {
    "owner": "lore-onco",
    "name": "Lore Onco",
    "slug": "lore-onco",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "auraonco",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f766e"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "O Lore Onco acede às suas fotos para a imagem de perfil e para anexar laudos e exames.",
        "NSCameraUsageDescription": "O Lore Onco usa a câmera para fotografar laudos e documentos.",
        "NSMicrophoneUsageDescription": "O microfone pode ser usado ao gravar vídeo com a câmera."
      }
    },
    "android": {
      "package": "com.auraonco.app",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f766e"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "auraonco",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "O Aura Onco precisa acessar suas fotos para anexar laudos e exames.",
          "cameraPermission": "O Aura Onco usa a câmera para fotografar laudos."
        }
      ],
      "expo-document-picker",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "O Aura Onco lê no Apple Saúde dados como frequência cardíaca, oxigênio no sangue (SpO₂) e variabilidade cardíaca (VFC) para complementar o seu acompanhamento, só com a sua autorização.",
          "NSHealthUpdateUsageDescription": "Se no futuro gravar dados no Apple Saúde, o Aura Onco só o fará com a sua autorização explícita.",
          "background": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://dxfjlpxxxxirvcwtxxdz.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImR4ZmpscHh4eHhpcnZjd3R4eGR6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU4MTg2NzUsImV4cCI6MjA5MTM5NDY3NX0.uOYyIXXnpRZ7VNaew7F5fyM6I7itFVTUrU2vjkkqNvY",
      "apiUrl": "http://192.168.3.16:3000",
      "router": {},
      "eas": {
        "projectId": "8f2dd6ff-ff84-49da-a538-75e10c2566ec"
      }
    }
  }
}
