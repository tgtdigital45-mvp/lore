# Copie para `.env` na raiz (não commite). O backend carrega `../../.env` e depois `backend/.env`.

# Obrigatório para API + app (Supabase Auth / PostgREST)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Agente (triagem)
GEMINI_API_KEY=

# Opcional
HOSPITAL_ALERT_WEBHOOK_URL=
OPENAI_API_KEY=
NODE_ENV=development

# Fase 2 — armazenamento de exames (R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
