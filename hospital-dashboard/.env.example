NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# URL do onco-backend (API staff, WhatsApp, etc.). Em dev, o Next.js reescreve /api/* para 127.0.0.1:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
# Opcional: destino do rewrite `/api/*` no `next.config.mjs` (SSR/build). Por omissão: http://127.0.0.1:3001
# BACKEND_URL=http://127.0.0.1:3001
